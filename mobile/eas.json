{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "staging": {
      "distribution": "internal",
      "ios": {
        "bundleIdentifier": "org.nself.nclaw.staging"
      },
      "android": {
        "package": "org.nself.nclaw.staging",
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "staging",
        "EXPO_PUBLIC_NSELF_API_URL": "https://api.staging.nself.org",
        "EXPO_PUBLIC_NCLAW_API_URL": "https://api.staging.nself.org"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "bundleIdentifier": "org.nself.nclaw"
      },
      "android": {
        "package": "org.nself.nclaw",
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_NSELF_API_URL": "https://api.nself.org",
        "EXPO_PUBLIC_NCLAW_API_URL": "https://api.nself.org"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "alisalaah@gmail.com",
        "ascAppId": "FILL_ME_IN",
        "appleTeamId": "FILL_ME_IN"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-account.json",
        "track": "production"
      }
    }
  }
}
