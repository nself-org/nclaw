<?xml version="1.0" encoding="utf-8"?>
<!--
  nclaw/mobile — Android Widget Manifest Configuration (Snippet)

  Purpose: Declares App Widget provider and receiver to Android system.
  Installation: Merge this snippet into the main AndroidManifest.xml (usually auto-generated by Expo).

  Constraint: Expo tooling must preserve this configuration when rebuilding; use expo-build-properties plugin
              to inject custom AndroidManifest entries if needed.
  SPORT: F08-SERVICE-INVENTORY.md (nclaw-mobile-rn android-widget-manifest)

  Integration: In app.json, add:
    ["expo-build-properties", {
      "android": {
        "manifestPatches": [
          { "selector": "manifest", "newElement": "uses-permission android:name=\"android.permission.RECEIVE_BOOT_COMPLETED\"" }
        ]
      }
    }]
-->

<!-- Add this receiver and widget provider declaration inside <application> -->
<receiver
  android:name="org.nself.nclaw.widget.NClawWidgetProvider"
  android:exported="true">

  <intent-filter>
    <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
    <action android:name="org.nself.nclaw.action.QUICK_CAPTURE" />
  </intent-filter>

  <meta-data
    android:name="android.appwidget.provider"
    android:resource="@xml/nclaw_appwidget_provider" />

</receiver>

<!-- Optional: Boot receiver to restore widget on device restart -->
<receiver
  android:name="org.nself.nclaw.widget.NClawWidgetBootReceiver"
  android:exported="false">

  <intent-filter>
    <action android:name="android.intent.action.BOOT_COMPLETED" />
  </intent-filter>

</receiver>
