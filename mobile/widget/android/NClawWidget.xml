<?xml version="1.0" encoding="utf-8"?>
<!--
  nclaw/mobile — Android App Widget Layout (XML)

  Purpose: Home screen widget that displays the last AI summary from shared SharedPreferences
           and provides a quick-capture button to open the app.
  Inputs:  Reads lastSummary + captureDeepLink from SharedPreferences (key: org.nself.nclaw.widget).
  Outputs: Widget UI on home screen; button tap opens nclaw://capture deep link via PendingIntent.
  Constraints:
    - App Widget requires Android API 16+.
    - RemoteViews is used for widget UI; limited to basic view types.
    - Widget data is cached in SharedPreferences; app updates via native bridge.
    - Widget provider (NClawWidgetProvider.kt) handles app group data + deep link tap.
  SPORT: F08-SERVICE-INVENTORY.md (nclaw-mobile-rn android-widget)
-->

<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@drawable/widget_background"
  android:padding="16dp">

  <!-- Header: ɳClaw Title -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:marginBottom="8dp">

    <TextView
      android:id="@+id/widget_title"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="ɳClaw"
      android:textSize="16sp"
      android:textStyle="bold"
      android:textColor="@android:color/white" />

    <ImageView
      android:layout_width="20dp"
      android:layout_height="20dp"
      android:src="@android:drawable/ic_popup_sync"
      android:tint="@android:color/darker_gray" />
  </LinearLayout>

  <!-- Divider -->
  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@android:color/darker_gray"
    android:layout_marginBottom="8dp" />

  <!-- Last Summary Text -->
  <TextView
    android:id="@+id/widget_summary"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:text="Start a conversation to see summaries here."
    android:textSize="12sp"
    android:textColor="@android:color/white"
    android:ellipsize="end"
    android:maxLines="2"
    android:gravity="top|left" />

  <!-- Quick Capture Button -->
  <Button
    android:id="@+id/widget_quick_capture_btn"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:text="Quick Capture"
    android:textSize="12sp"
    android:textColor="@android:color/white"
    android:background="@drawable/widget_button_background"
    android:layout_marginTop="8dp" />

</LinearLayout>
