<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Set APPLE_TEAM_ID in CI secrets (e.g. ABC123XYZ9) -->
	<key>teamID</key>
	<string>$(APPLE_TEAM_ID)</string>

	<key>method</key>
	<string>app-store</string>

	<key>uploadBitcode</key>
	<false/>

	<key>uploadSymbols</key>
	<true/>

	<key>compileBitcode</key>
	<false/>

	<key>destination</key>
	<string>upload</string>

	<key>signingStyle</key>
	<string>automatic</string>

	<key>signingCertificate</key>
	<string>iPhone Distribution</string>

	<key>provisioningProfiles</key>
	<dict>
		<key>com.nself.claw</key>
		<string>match AppStore com.nself.claw</string>
		<key>com.nself.claw.NotificationService</key>
		<string>match AppStore com.nself.claw.NotificationService</string>
		<key>com.nself.claw.ShareExtension</key>
		<string>match AppStore com.nself.claw.ShareExtension</string>
		<key>com.nself.claw.ClawWidget</key>
		<string>match AppStore com.nself.claw.ClawWidget</string>
	</dict>
</dict>
</plist>
