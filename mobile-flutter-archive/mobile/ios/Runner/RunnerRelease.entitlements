<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- S22-T04: Production entitlements — matches aps-environment=production
	     for App Store builds. Xcode project selects this file when the
	     build configuration is Release. -->
	<key>aps-environment</key>
	<string>production</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:claw.nself.org</string>
		<string>applinks:nself.org</string>
	</array>
</dict>
</plist>
