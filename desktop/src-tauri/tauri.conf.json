{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ɳClaw",
  "version": "1.1.1",
  "identifier": "org.nself.nclaw",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ɳClaw",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "settings",
        "title": "ɳClaw Settings",
        "url": "/settings",
        "width": 900,
        "height": 700,
        "visible": false,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "debug",
        "title": "ɳClaw Debug",
        "url": "/debug",
        "width": 1000,
        "height": 600,
        "visible": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' tauri: ipc: http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "window-state": {},
    "autostart": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/tray-connected.png": "icons/tray-connected.png",
      "icons/tray-offline.png": "icons/tray-offline.png",
      "icons/tray-syncing.png": "icons/tray-syncing.png"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
