# ɳClaw Backend — Environment Template
# Copy to .env and fill in your values.
# DO NOT commit .env to version control.
#
# See backend/README.md for setup instructions.

# =====================================================================
# nSelf License Key
# =====================================================================
# Required: ɳClaw bundle ($0.99/mo or $9.99/yr) or ɳSelf+ ($3.99/mo or $39.99/yr) at nself.org/pricing
# Format: nself_pro_ followed by 32+ characters
NSELF_PLUGIN_LICENSE_KEY=nself_pro_your_key_here

# =====================================================================
# Core nSelf Config
# =====================================================================
NSELF_DOMAIN=localhost
NSELF_ENV=development

# =====================================================================
# Database
# =====================================================================
POSTGRES_PASSWORD=changeme_secure_password_here

# =====================================================================
# Hasura GraphQL
# =====================================================================
HASURA_GRAPHQL_ADMIN_SECRET=changeme_admin_secret_here

# =====================================================================
# Auth (nHost)
# =====================================================================
AUTH_JWT_SECRET=changeme_jwt_secret_at_least_32_chars_here

# =====================================================================
# AI Provider (required for nself-ai plugin)
# =====================================================================
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o

# =====================================================================
# Optional: Google Integration (nself-google plugin)
# =====================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================================================================
# Optional: Browser Automation (nself-browser plugin)
# =====================================================================
BROWSER_CDP_URL=

# =====================================================================
# Optional: SMTP / Notifications (nself-notify plugin)
# =====================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# =====================================================================
# Storage (auto-configured by nself init)
# =====================================================================
MINIO_ROOT_USER=nself
MINIO_ROOT_PASSWORD=changeme_minio_password_here

# =====================================================================
# WebAuthn / Passkey Authentication (requires plugins-pro paid/auth v1.0.17+)
# =====================================================================
# Set WEBAUTHN_ENABLED=true to enable passkey sign-in (requires HTTPS + domain)
WEBAUTHN_ENABLED=false
# Relying Party ID — must match the domain where the app is served (e.g. "claw.example.com")
WEBAUTHN_RP_ID=localhost
# Relying Party display name — shown in the browser passkey dialog
WEBAUTHN_RP_NAME=nSelf
